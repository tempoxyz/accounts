{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tempo-connect",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-02-13",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [{ "binding": "KV", "id": "0bf8c7740a1e46e38f22cdee1ffc9a0b" }],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "",
      "localConnectionString": "postgresql://tempo:tempo@host.docker.internal:5432/connect"
    }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/.well-known/*", "/pho", "/pho/*", "/sentry-tunnel"]
  }
}
