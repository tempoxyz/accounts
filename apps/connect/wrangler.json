{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tempo-connect",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-02-13",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [{ "binding": "KV", "id": "0bf8c7740a1e46e38f22cdee1ffc9a0b" }],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "",
      "localConnectionString": "postgresql://tempo:tempo@host.docker.internal:5432/connect"
    }
  ],
  "ratelimits": [
    {
      "name": "OTP_EMAIL_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 5, "period": 60 }
    },
    {
      "name": "OTP_IP_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 20, "period": 60 }
    },
    {
      "name": "OTP_VERIFY_EMAIL_RATE_LIMITER",
      "namespace_id": "1003",
      "simple": { "limit": 10, "period": 60 }
    }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/",
      "/design",
      "/design/*",
      "/rpc",
      "/rpc/*",
      "/api/*",
      "/.well-known/*",
      "/pho",
      "/pho/*",
      "/sentry-tunnel"
    ]
  }
}
