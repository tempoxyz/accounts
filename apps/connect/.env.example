# Skip email OTP verification in development
BYPASS_EMAIL_OTP=true
# (required) PostgreSQL connection string for the connect database
DATABASE_URL=postgres://tempo:tempo@host.docker.internal:5432/connect
# Mailgun API key for sending email OTPs
MAILGUN_API_KEY=
# Mailgun domain for sending emails
MAILGUN_DOMAIN=
# Relay API key for cross-chain bridge deposits
RELAY_API_KEY=
# (required) Private key for the relay fee payer (note: anvil account[0] — "test test test ... junk" mnemonic)
RELAY_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# (required) Ed25519 private key for signing session tokens (note: test key pair)
SESSION_PRIVATE_KEY={"key_ops":["sign"],"ext":true,"alg":"Ed25519","crv":"Ed25519","d":"X4r_1njmh53RSO6lQSqJAWOsrUMwoPZdzOEIY5JDJVE","x":"isqJogp6bz4xx5aIxG6sR7YiPMNm2qKFZL7LiWJfh68","kty":"OKP"}
# (required) Ed25519 public key for verifying session tokens
SESSION_PUBLIC_KEY={"key_ops":["verify"],"ext":true,"alg":"Ed25519","crv":"Ed25519","x":"isqJogp6bz4xx5aIxG6sR7YiPMNm2qKFZL7LiWJfh68","kty":"OKP"}
# Sentry DSN for server-side error reporting
SENTRY_DSN=
# Private key for bridge e2e tests
TEST_BRIDGE_PRIVATE_KEY=
# PostHog project key for client-side analytics
VITE_POSTHOG_KEY=
# Sentry DSN for client-side error reporting
VITE_SENTRY_DSN=
